{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "Markdown Desk",
  "version": "26.4.1",
  "identifier": "com.markdowndesk.app",
  "build": {
    "beforeBuildCommand": "sh scripts/prepare-frontend.sh",
    "beforeDevCommand": "sh scripts/prepare-frontend.sh",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": "default-src 'self' ipc: asset: tauri:; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdnjs.cloudflare.com https://cdn.jsdelivr.net https://unpkg.com; style-src 'self' 'unsafe-inline' https://cdnjs.cloudflare.com https://cdn.jsdelivr.net https://fonts.googleapis.com; font-src 'self' https://cdnjs.cloudflare.com https://cdn.jsdelivr.net https://fonts.gstatic.com; img-src 'self' data: blob: asset: https:; connect-src 'self' ipc: asset: tauri: https:"
    },
    "windows": [
      {
        "label": "main",
        "title": "Markdown Desk",
        "width": 1200,
        "height": 800,
        "minWidth": 600,
        "minHeight": 400,
        "resizable": true,
        "decorations": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/icon.icns",
      "icons/icon.png"
    ],
    "fileAssociations": [
      {
        "ext": ["md", "markdown"],
        "name": "Markdown Document",
        "role": "Editor"
      }
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDZBQzJENkU1QzQyQkM4MzYKUldRMnlDdkU1ZGJDYWpuSUpYWWVpQWNBSE9PWERRT3Evc2VGUlpSeVFHVnpISlVzbE1URTdIaGwK",
      "endpoints": [
        "https://github.com/jhrepo/markdown-desk/releases/latest/download/latest.json"
      ]
    }
  }
}
